<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayoutOff"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bright_snow"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/headerLayoutOff"
        android:layout_width="match_parent"
        android:layout_height="125dp"
        android:background="@drawable/bg_header"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="38dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hai"
            android:textColor="@color/black_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDescOff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Kamu belum terhubung ke internet loh!"
            android:textColor="@color/black_text"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardAnimOff"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            app:cardBackgroundColor="@color/lavender_grey"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieOffline"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardBottomOff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/sweet_salmon"
            app:cardCornerRadius="100dp"
            app:cardElevation="6dp">

            <TextView
                android:id="@+id/tvBottomOff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="Sambungin smartphone Ke jaringan dulu ya!"
                android:textColor="@color/black_text"
                android:textSize="14sp" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>